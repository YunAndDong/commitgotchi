# Commit-Gotchi — local integrated environment template.
# Copy to .env and adjust. .env is gitignored; never commit real secrets.
#   cp .env.example .env
#
# This root .env is the SSOT for integrated docker-compose runs. Per-service
# env files such as fastapi/.env and vue/.env.local are only for standalone
# non-Docker development.

# ---- PostgreSQL (shared instance, one database per backend) ----
DB_USER=commitgotchi
DB_PASSWORD=commitgotchi-local-password
DB_PORT=5432

# Spring Boot (System of Record) database — created via POSTGRES_DB.
SPRING_DB_NAME=commitgotchi

# FastAPI (Intelligence) database — created by postgres/init script.
FASTAPI_DB_NAME=commitgotchi_ai

# ---- Spring Boot ----
SPRING_PORT=8080
SPRING_PROFILES_ACTIVE=local
# Generate a unique 256-bit or stronger key, for example:
#   openssl rand -base64 32
# Never commit the generated value.
# This sample value is valid only for local config dry-runs.
JWT_SECRET_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
JWT_ISSUER=commitgotchi-springboot
# Comma-separated exact browser origins. Wildcards and origin patterns are rejected.
# Local compose/Vite: http://localhost:5173.
# Production uses https://commitgotchi.store in .env.prod.example. The trusted
# Chrome extension origin is added by Spring Boot code.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Refresh cookie secure handling:
# - local/dev/test: false by default, SameSite=Lax
# - prod profile: true by application.yml, Secure; SameSite=None
# Do not set REFRESH_COOKIE_SECURE=false in production.
REFRESH_COOKIE_SECURE=false
# Shared by Spring Boot internal callback endpoints and FastAPI callback client.
SPRING_INTERNAL_API_SECRET=commitgotchi-local-internal-secret
# Flow C image generation. Local compose routes Spring -> FastAPI over the service network.
CHARACTER_IMAGE_ENABLED=true
CHARACTER_IMAGE_BASE_URL=http://fastapi:8000
CHARACTER_IMAGE_FALLBACK_SPRITE_SHEET_URL=/character-assets/default_image1.png

# Quiz grading is Spring -> FastAPI internal traffic. Set to true when exercising
# the integrated AI grading flow locally.
QUIZ_GRADING_ENABLED=false
QUIZ_GRADING_BASE_URL=http://fastapi:8000
QUIZ_GRADING_CALLBACK_URL=http://springboot:8080/api/internal/quizzes/grade-result

# Report scheduler/dispatcher. The queue is off by default until local SQS
# values are supplied.
REPORT_MIDNIGHT_SCHEDULER_ENABLED=true

# ---- AWS SQS report request queue ----
# Keep real AWS credentials in local .env, deployment secrets, or an IAM role.
# Do not commit live keys.
REPORT_REQUEST_QUEUE_ENABLED=false
AWS_REGION=ap-northeast-2
AWS_SQS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
REPORT_REQUEST_QUEUE_ACCESS_KEY_ID=
REPORT_REQUEST_QUEUE_SECRET_ACCESS_KEY=
REPORT_REQUEST_QUEUE_SESSION_TOKEN=
REPORT_REQUEST_QUEUE_NAME=
REPORT_REQUEST_QUEUE_URL=
REPORT_REQUEST_QUEUE_ARN=
REPORT_REQUEST_DLQ_NAME=
REPORT_REQUEST_DLQ_URL=
REPORT_REQUEST_DLQ_ARN=
REPORT_REQUEST_DISPATCHER_ENABLED=false

# ---- S3 character image storage (future adapter; prefix separates envs) ----
S3_BUCKET_NAME=commitgotchi-character-images
S3_OBJECT_PREFIX=dev/

# ---- FastAPI ----
FASTAPI_PORT=8000
SPRING_BOOT_INTERNAL_BASE_URL=http://springboot:8080
SPRING_REPORT_CALLBACK_PATH=/api/report
SPRING_QUIZ_GRADE_RESULT_PATH=/api/internal/quizzes/grade-result
SPRING_CALLBACK_TIMEOUT_SECONDS=10

# Gemini AI features. Replace GEMINI_API_KEY before using image generation,
# quiz grading, report analysis, or embedding generation against the real API.
GEMINI_API_KEY=replace-with-local-gemini-key
GEMINI_QUIZ_GRADER_MODEL=gemini-3.1-flash-lite
GEMINI_REPORT_ANALYZER_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=768
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_TIMEOUT_SECONDS=30
GEMINI_IMAGE_RETRY_LIMIT=1
CHARACTER_IMAGE_STORAGE_ROOT=runtime/data/character-images

# ---- API-only Nginx (prod compose only; ignored by local docker-compose.yml) ----
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_LETSENCRYPT_DIR=/etc/letsencrypt
NGINX_CERTBOT_WEBROOT=/var/www/certbot

# ---- Vue local preview / Chrome extension build only ----
VUE_PORT=5173
# Local preview uses http://localhost:8080. Extension release builds outside the
# backend deployment pipeline should use https://commitgotchi.store.
# Do not put VITE_API_BASE_URL in .env.prod; it is not a backend runtime env.
VITE_API_BASE_URL=http://localhost:8080
