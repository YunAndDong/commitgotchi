# Commit-Gotchi — environment template.
# Copy to .env and adjust. .env is gitignored; never commit real secrets.
#   cp .env.example .env

# ---- PostgreSQL (shared instance, one database per backend) ----
DB_USER=commitgotchi
DB_PASSWORD=change-me-in-prod
DB_PORT=5432

# Spring Boot (System of Record) database — created via POSTGRES_DB.
SPRING_DB_NAME=commitgotchi

# FastAPI (Intelligence) database — created by postgres/init script.
FASTAPI_DB_NAME=commitgotchi_ai

# ---- Spring Boot ----
SPRING_PORT=8080
# Local docker-compose currently starts Spring Boot with the local profile.
# For server deployments, set SPRING_PROFILES_ACTIVE=prod in the deployment
# environment instead of relying on this local compose template.
# SPRING_PROFILES_ACTIVE=prod
# Generate a unique 256-bit or stronger key, for example:
#   openssl rand -base64 32
# Never commit the generated value.
JWT_SECRET_BASE64=
JWT_ISSUER=commitgotchi-springboot
# Comma-separated exact browser origins. Wildcards and origin patterns are rejected.
# COR-1.2 production default: same-origin reverse proxy.
# - Local compose/Vite: http://localhost:5173
# - Production web: https://app.example.com
# - Chrome extension origin is added by Spring Boot and does not need to be
#   repeated here, but prod still requires at least one HTTPS web origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Refresh cookie secure handling:
# - local/dev/test: false by default, SameSite=Lax
# - prod profile: true by application.yml, Secure; SameSite=None
# Do not set REFRESH_COOKIE_SECURE=false in production.
# REFRESH_COOKIE_SECURE=true
# Shared by Spring Boot internal callback endpoints and FastAPI callback client.
SPRING_INTERNAL_API_SECRET=change-me-in-prod
# Flow C image generation. Local compose routes Spring -> FastAPI over the service network.
CHARACTER_IMAGE_ENABLED=true

# ---- AWS SQS report request queue ----
# Keep real AWS credentials in local .env, deployment secrets, or an IAM role.
# Do not commit live keys.
REPORT_REQUEST_QUEUE_ENABLED=false
AWS_REGION=ap-northeast-2
AWS_SQS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
REPORT_REQUEST_QUEUE_ACCESS_KEY_ID=
REPORT_REQUEST_QUEUE_SECRET_ACCESS_KEY=
REPORT_REQUEST_QUEUE_SESSION_TOKEN=
REPORT_REQUEST_QUEUE_NAME=
REPORT_REQUEST_QUEUE_URL=
REPORT_REQUEST_QUEUE_ARN=
REPORT_REQUEST_DLQ_NAME=
REPORT_REQUEST_DLQ_URL=
REPORT_REQUEST_DLQ_ARN=

# ---- FastAPI ----
FASTAPI_PORT=8000

# ---- Vue ----
VUE_PORT=5173
# Base URL the browser uses to reach Spring Boot.
# - Local docker-compose / Vite dev: http://localhost:8080
# - Production web with same-origin reverse proxy: leave empty at Vue build time
#   so requests go to /api/** on https://app.example.com
# - Production extension build: use https://app.example.com because
#   chrome-extension:// pages cannot resolve relative /api/** to the web origin.
VITE_API_BASE_URL=http://localhost:8080
