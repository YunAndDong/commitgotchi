# Vue (Vite) frontend env template. Copy to .env.local for local dev.
#   cp .env.example .env.local
#
# Base URL the browser uses to reach the Spring Boot SoR API.
# Local Vite dev / local docker-compose:
#   VITE_API_BASE_URL=http://localhost:8080
# Production web default (COR-1.2 same-origin reverse proxy):
#   VITE_API_BASE_URL=
# Production Chrome extension build:
#   VITE_API_BASE_URL=https://app.example.com
#
# Empty value means same-origin relative /api/** requests. Do not use an empty
# value for extension builds; chrome-extension:// pages would resolve /api/**
# under the extension origin, not under the public web origin.
VITE_API_BASE_URL=http://localhost:8080
