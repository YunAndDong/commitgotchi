# Commit-Gotchi FastAPI local development environment template.
# Copy this file to fastapi/.env and fill local secrets there.
#   cd fastapi
#   cp .env.example .env
#
# fastapi/.env is gitignored. Never commit real API keys.

# ---- PostgreSQL for local FastAPI runs ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=commitgotchi
DB_PASSWORD=commitgotchi
FASTAPI_DB_NAME=commitgotchi_ai

# ---- Gemini quiz grader ----
GEMINI_API_KEY=
GEMINI_QUIZ_GRADER_MODEL=gemini-3.1-flash-lite
# Fallback candidate if needed:
# GEMINI_QUIZ_GRADER_MODEL=gemini-2.5-flash-lite

# ---- Spring Boot internal callbacks ----
SPRING_BOOT_INTERNAL_BASE_URL=http://localhost:8080
SPRING_INTERNAL_API_SECRET=
SPRING_REPORT_CALLBACK_PATH=/api/report
SPRING_QUIZ_GRADE_RESULT_PATH=/api/internal/quizzes/grade-result
SPRING_CALLBACK_TIMEOUT_SECONDS=10

# ---- Report SQS consumer ----
AWS_REGION=ap-northeast-2
AWS_SQS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
REPORT_REQUEST_QUEUE_URL=
REPORT_REQUEST_DLQ_URL=
